# Vercel Postgres Configuration
# Get these values from your Vercel project dashboard

# PostgreSQL Database URL
POSTGRES_URL=

# PostgreSQL Database User
POSTGRES_USER=

# PostgreSQL Database Password
POSTGRES_PASSWORD=

# PostgreSQL Database Name
POSTGRES_DATABASE=

# PostgreSQL Host (optional, if not included in URL)
POSTGRES_HOST=

# PostgreSQL Port (optional, if not included in URL)
POSTGRES_PORT=

# PostgreSQL Prisma URL (optional, if using Prisma)
POSTGRES_PRISMA_URL=

# Application URL (for Vercel deployment)
NEXT_PUBLIC_APP_URL=
